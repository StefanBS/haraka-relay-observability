{
  "uid": "relay-observability",
  "title": "SMTP Relay Health",
  "schemaVersion": 39,
  "refresh": "5s",
  "timezone": "browser",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Health: alerts firing / % delivered <60s (5m)",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "% delivered <60s" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "max", "value": 1 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "green", "value": 0.99 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "legendFormat": "alerts firing",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "sum(rate(relay_delivery_duration_seconds_bucket{le=\"60\"}[5m])) / sum(rate(relay_delivery_duration_seconds_count[5m]))",
          "legendFormat": "% delivered <60s",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Flow: received vs delivered (msg/s)",
      "gridPos": { "h": 7, "w": 16, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": { "defaults": { "unit": "mps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "rate(relay_received_total[1m])", "legendFormat": "received" },
        { "refId": "B", "expr": "rate(relay_delivered_total[1m])", "legendFormat": "delivered" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Failures: deferrals by reason, dead letters, notifications",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (reason) (rate(relay_deferred_total[1m]))", "legendFormat": "deferred: {{reason}}" },
        { "refId": "B", "expr": "rate(relay_bounced_total[1m])", "legendFormat": "dead-lettered (retries exhausted)" },
        { "refId": "C", "expr": "rate(relay_ndr_sent_total[1m])", "legendFormat": "senders notified" },
        { "refId": "D", "expr": "rate(relay_ndr_failures_total[1m])", "legendFormat": "notification failed (sender uninformed)" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Delivery latency (accept to upstream handoff)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.5, sum by (le) (rate(relay_delivery_duration_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(relay_delivery_duration_seconds_bucket[5m])))", "legendFormat": "p95" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Queue: depth, oldest age, dead-lettered",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "oldest age (s)" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "targets": [
        { "refId": "A", "expr": "relay_queue_depth", "legendFormat": "depth" },
        { "refId": "B", "expr": "relay_queue_oldest_age_seconds", "legendFormat": "oldest age (s)" },
        { "refId": "C", "expr": "relay_dead_letter_depth", "legendFormat": "dead-letter depth (needs a human)" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Back-pressure: tempfailed RCPTs (msg/s)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prom" },
      "fieldConfig": { "defaults": { "unit": "mps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "rate(relay_backpressure_rejections_total[1m])", "legendFormat": "450 tempfails (back-pressure)" }
      ]
    }
  ]
}
