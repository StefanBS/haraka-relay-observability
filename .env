# Host-side ports
SMTP_PORT=2525
METRICS_PORT=9090
MAILPIT_UI_PORT=8025
TOXIPROXY_API_PORT=8474
# Host side only; the container listen port is fixed in toxiproxy/toxiproxy.json
# (UPSTREAM_PORT couples to that JSON value, not to this var).
TOXIPROXY_SMTP_PORT=2526
PROMETHEUS_PORT=9091
GRAFANA_PORT=3000

# Relay behaviour
UPSTREAM_HOST=toxiproxy
UPSTREAM_PORT=2526
# Bounce notices go here, deliberately not via toxiproxy: an NDR targets the
# sender's own provider, which does not fail with the upstream (see README).
SENDER_MX_HOST=mailpit
SENDER_MX_PORT=1025
QUEUE_MAX_DEPTH=200
# Haraka temp_fail_intervals syntax: "30s*20" = 20 retries, 30s apart, then
# dead-letter. Demo value; a production relay retries for days.
RETRY_INTERVAL=30s*20
# Where retry-exhausted mail is preserved for manual replay.
DEAD_LETTER_DIR=/data/dead-letter

# Alerting
# seconds; substituted into the PromQL alert expr, must stay a bare number
QUEUE_AGE_THRESHOLD=60
